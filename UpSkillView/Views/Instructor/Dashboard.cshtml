@model List<Application.Courses.DTOs.Course.CourseSummaryDto>
@{
    ViewData["Title"] = "Instructor Dashboard";
    Layout = "_DashboardLayout";
    var apiBase = ViewBag.ApiBaseUrl as string ?? "";

    int totalCourses    = Model?.Count ?? 0;
    int published       = Model?.Count(c => c.Status == Domain.Enum.CourseStatus.Published) ?? 0;
    int drafts          = Model?.Count(c => c.Status == Domain.Enum.CourseStatus.Draft) ?? 0;
    int underReview     = Model?.Count(c => c.Status == Domain.Enum.CourseStatus.SubmittedForApproval) ?? 0;
    int totalStudents   = Model?.Sum(c => c.EnrollmentCount) ?? 0;
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Instructor Dashboard</h2>
        <p class="text-muted mb-0">Welcome back, <strong>@(User.Identity?.Name ?? "Instructor")</strong>! Here's an overview of your teaching.</p>
    </div>
    <a asp-action="MyCourses" class="btn btn-outline-primary d-none d-sm-flex align-items-center gap-2">
        <i class="bi bi-journal-code"></i> Manage Courses
    </a>
</div>

<!-- Stats Row -->
<div class="row g-4 mb-4">

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 card-hover">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="text-muted mb-0 fw-normal">Total Courses</h6>
                    <div class="p-2 rounded" style="background:rgba(37,99,235,.1);">
                        <i class="bi bi-journal-code text-primary fs-5"></i>
                    </div>
                </div>
                <h2 class="fw-bold mb-0">@totalCourses</h2>
                <small class="text-muted">All your created courses</small>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 card-hover">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="text-muted mb-0 fw-normal">Published</h6>
                    <div class="p-2 rounded" style="background:rgba(22,163,74,.1);">
                        <i class="bi bi-broadcast text-success fs-5"></i>
                    </div>
                </div>
                <h2 class="fw-bold mb-0">@published</h2>
                <small class="text-muted">Live and visible to students</small>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 card-hover">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="text-muted mb-0 fw-normal">Drafts / Review</h6>
                    <div class="p-2 rounded" style="background:rgba(245,158,11,.1);">
                        <i class="bi bi-hourglass-split text-warning fs-5"></i>
                    </div>
                </div>
                <h2 class="fw-bold mb-0">@(drafts + underReview)</h2>
                <small class="text-muted">@drafts draft · @underReview under review</small>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 card-hover">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="text-muted mb-0 fw-normal">Total Students</h6>
                    <div class="p-2 rounded" style="background:rgba(139,92,246,.1);">
                        <i class="bi bi-people text-purple fs-5" style="color:#7c3aed!important;"></i>
                    </div>
                </div>
                <h2 class="fw-bold mb-0">@totalStudents</h2>
                <small class="text-muted">Across all your courses</small>
            </div>
        </div>
    </div>

</div>

<!-- Recent Courses Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold">Recent Courses</h6>
        <a asp-action="MyCourses" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Course</th>
                            <th>Category</th>
                            <th>Students</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th class="pe-4 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in Model.OrderByDescending(c => c.CreatedAt).Take(5))
                        {
                            var thumbnailSrc = !string.IsNullOrEmpty(course.ThumbnailUrl)
                                ? apiBase + course.ThumbnailUrl
                                : "https://placehold.co/80x50/2563EB/FFFFFF?text=LMS";

                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@thumbnailSrc" alt="thumbnail"
                                             style="width:60px; height:40px; object-fit:cover; border-radius:6px;"
                                             onerror="this.src='https://placehold.co/80x50/2563EB/FFFFFF?text=LMS'" />
                                        <div>
                                            <div class="fw-semibold" style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                                @course.Title
                                            </div>
                                            <small class="text-muted">@course.SectionCount sections</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-primary-soft">@course.CategoryName</span>
                                </td>
                                <td>
                                    <span class="fw-semibold">@course.EnrollmentCount</span>
                                </td>
                                <td>
                                    @if (course.Price == 0)
                                    {
                                        <span class="badge bg-success-soft">Free</span>
                                    }
                                    else
                                    {
                                        <span class="fw-semibold">$@course.Price.ToString("0.00")</span>
                                    }
                                </td>
                                <td>
                                    @if (course.Status == Domain.Enum.CourseStatus.Published)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-broadcast me-1"></i>Published</span>
                                    }
                                    else if (course.Status == Domain.Enum.CourseStatus.SubmittedForApproval)
                                    {
                                        <span class="badge bg-info text-dark"><i class="bi bi-hourglass-split me-1"></i>Under Review</span>
                                    }
                                    else if (course.Status == Domain.Enum.CourseStatus.Archived)
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-archive me-1"></i>Archived</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-pencil me-1"></i>Draft</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="EditCourse" asp-route-id="@course.Id"
                                           class="btn btn-sm btn-outline-primary" title="Edit Course">
                                            <i class="bi bi-pencil-square"></i> Edit
                                        </a>
                                        <a asp-action="ManageContent" asp-route-id="@course.Id"
                                           class="btn btn-sm btn-outline-success" title="Manage Curriculum">
                                            <i class="bi bi-collection"></i> Curriculum
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-journal-plus" style="font-size:3rem; color:var(--text-muted);"></i>
                <h5 class="mt-3 mb-2">No courses yet</h5>
                <p class="text-muted mb-4">Create your first course to start teaching.</p>
                <a asp-action="CreateCourse" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-2"></i> Create Course
                </a>
            </div>
        }
    </div>
</div>
