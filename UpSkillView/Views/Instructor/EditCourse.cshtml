@model UpSkillView.Models.Instructor.EditCourseViewModel
@using Application.Courses.DTOs.Category
@{
    ViewData["Title"] = "Edit Course";
    Layout = "_DashboardLayout";
    var categories = ViewBag.Categories as List<CategoryResponseDto> ?? new List<CategoryResponseDto>();
}

<form asp-action="EditCourse" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" id="editCourseForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ExistingThumbnailUrl" />

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Instructor" asp-action="MyCourses" class="text-decoration-none">My Courses</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Edit Course</li>
        </ol>
    </nav>

    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-3 gap-3">
        <div>
            <h2 class="mb-1">Edit Course</h2>
            <p class="text-muted mb-0">Updating: <strong>@Model.CourseTitle</strong></p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="MyCourses" class="btn btn-outline-secondary" id="cancelBtn">
                <i class="bi bi-x-lg me-1"></i> Cancel
            </a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save me-1"></i> Save Changes
            </button>
        </div>
    </div>

    @* Draft reset warning — always visible at the top *@
    <div class="alert alert-warning d-flex align-items-start mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2 mt-1 flex-shrink-0"></i>
        <small>
            <strong>Heads up:</strong> Saving any changes will reset this course's status back to
            <strong>Draft</strong> and it will need to be re-submitted for admin review before going live again.
        </small>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <div asp-validation-summary="ModelOnly"></div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Wizard Tabs -->
    <ul class="nav nav-pills mb-4 bg-white p-2 rounded shadow-sm border" id="editCourseTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="edit-basic-tab" data-bs-toggle="pill"
                    data-bs-target="#edit-basic" type="button" role="tab" aria-selected="true">
                <i class="bi bi-1-circle me-1"></i> Basic Info
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="edit-details-tab" data-bs-toggle="pill"
                    data-bs-target="#edit-details" type="button" role="tab" aria-selected="false">
                <i class="bi bi-2-circle me-1"></i> Details &amp; Media
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="edit-sessions-tab" data-bs-toggle="pill"
                    data-bs-target="#edit-sessions" type="button" role="tab" aria-selected="false">
                <i class="bi bi-3-circle me-1"></i> Sessions
            </button>
        </li>
    </ul>

    <div class="tab-content" id="editCourseTabsContent">

        <!-- ── Step 1: Basic Info ───────────────────────────────────────── -->
        <div class="tab-pane fade show active" id="edit-basic" role="tabpanel">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="mb-4"><i class="bi bi-info-circle me-2 text-primary"></i>Course Information</h5>

                    <div class="mb-4">
                        <label asp-for="CourseTitle" class="form-label">
                            Course Title <span class="text-danger">*</span>
                        </label>
                        <input asp-for="CourseTitle" class="form-control"
                               placeholder="e.g. Learn Python from Scratch" />
                        <span asp-validation-for="CourseTitle" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="CourseSubtitle" class="form-label">
                            Course Subtitle <span class="text-danger">*</span>
                        </label>
                        <input asp-for="CourseSubtitle" class="form-control"
                               placeholder="e.g. Master Python 3 with real-world projects" />
                        <span asp-validation-for="CourseSubtitle" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="CourseDescription" class="form-label">
                            Course Description <span class="text-danger">*</span>
                        </label>
                        <textarea asp-for="CourseDescription" class="form-control" rows="7"
                                  placeholder="Provide a detailed description of your course..."></textarea>
                        <span asp-validation-for="CourseDescription" class="text-danger small"></span>
                    </div>

                    <div class="text-end mt-4">
                        <button type="button" class="btn btn-primary"
                                onclick="document.getElementById('edit-details-tab').click()">
                            Next: Details &amp; Media <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Step 2: Details & Media ─────────────────────────────────── -->
        <div class="tab-pane fade" id="edit-details" role="tabpanel">

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="mb-4"><i class="bi bi-tags me-2 text-primary"></i>Category &amp; Pricing</h5>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="CategoryId" class="form-label">
                                Category <span class="text-danger">*</span>
                            </label>
                            <select asp-for="CategoryId" class="form-select">
                                <option value="">— Select a category —</option>
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label asp-for="Level" class="form-label">
                                Level <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Level" class="form-select">
                                <option value="3">All Levels</option>
                                <option value="0">Beginner</option>
                                <option value="1">Intermediate</option>
                                <option value="2">Advanced</option>
                            </select>
                            <span asp-validation-for="Level" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="Price" class="form-label">
                                Price (USD) <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Price" type="number" step="0.01" min="0"
                                       class="form-control" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                            <div class="form-text">Set to 0 for a free course.</div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label asp-for="Language" class="form-label">
                                Language <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Language" class="form-select">
                                <option value="English">English</option>
                                <option value="Arabic">Arabic</option>
                                <option value="Spanish">Spanish</option>
                                <option value="French">French</option>
                            </select>
                            <span asp-validation-for="Language" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="mb-1"><i class="bi bi-image me-2 text-primary"></i>Course Thumbnail</h5>
                    <p class="text-muted small mb-4">Leave blank to keep the existing image.</p>

                    <div class="row align-items-center mb-4">
                        <div class="col-md-4 mb-3 mb-md-0">
                            <div class="rounded overflow-hidden position-relative"
                                 style="height:180px; border:2px dashed var(--border-color);" id="previewBox">
                                @if (!string.IsNullOrEmpty(Model.ExistingThumbnailUrl))
                                {
                                    <img id="previewImg" src="@Model.ExistingThumbnailUrl"
                                         alt="Current Thumbnail"
                                         style="width:100%; height:100%; object-fit:cover;"
                                         onerror="this.style.display='none'; document.getElementById('previewFallback').style.display='flex'" />
                                }
                                <div id="previewFallback"
                                     class="d-@(string.IsNullOrEmpty(Model.ExistingThumbnailUrl) ? "flex" : "none") align-items-center justify-content-center text-muted h-100">
                                    <div class="text-center">
                                        <i class="bi bi-image fs-1 d-block mb-2"></i>
                                        <span class="small">No image yet</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <p class="text-muted small mb-2">
                                Recommended size: <strong>750×422px</strong><br />
                                Accepted: JPG, PNG, GIF, WebP &middot; Max: <strong>5MB</strong>
                            </p>
                            <input asp-for="CourseImage" type="file" class="form-control"
                                   accept="image/*" id="thumbnailInput" />
                            <span class="text-muted small mt-1 d-block" id="fileInfo"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-3">
                        <button type="button" class="btn btn-outline-secondary"
                                onclick="document.getElementById('edit-basic-tab').click()">
                            <i class="bi bi-arrow-left me-1"></i> Previous
                        </button>
                        <button type="button" class="btn btn-primary"
                                onclick="document.getElementById('edit-sessions-tab').click()">
                            Next: Sessions <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>
            </div>

        </div>

        <!-- ── Step 3: Sessions ─────────────────────────────────────────── -->
        <div class="tab-pane fade" id="edit-sessions" role="tabpanel">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="mb-0"><i class="bi bi-collection-play me-2 text-primary"></i>Course Sessions (Sections &amp; Lessons)</h5>
                        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addSectionModal">
                            <i class="bi bi-plus-circle"></i> Add New Section
                        </button>
                    </div>

                    <div class="accordion mb-4" id="courseSections">
                        @if (Model.Sections != null && Model.Sections.Any())
                        {
                            for (int i = 0; i < Model.Sections.Count; i++)
                            {
                                var sec = Model.Sections[i];
                                <div class="accordion-item mb-3 border rounded shadow-sm">
                                    <h2 class="accordion-header" id="heading-@sec.Id">
                                        <button class="accordion-button @(i == 0 ? "" : "collapsed") fw-bold bg-light text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@sec.Id" aria-expanded="@(i == 0 ? "true" : "false")" aria-controls="collapse-@sec.Id">
                                            @sec.Title <span class="badge bg-secondary ms-2">Order: @sec.DisplayOrder</span>
                                        </button>
                                    </h2>
                                    <div id="collapse-@sec.Id" class="accordion-collapse collapse @(i == 0 ? "show" : "")" aria-labelledby="heading-@sec.Id" data-bs-parent="#courseSections">
                                        <div class="accordion-body">
                                            <div class="d-flex justify-content-end mb-3 gap-2">
                                                <button type="button" class="btn btn-sm btn-outline-success" onclick="openAddLessonModal(@sec.Id)">
                                                    <i class="bi bi-plus-lg"></i> Add Lesson
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteSection(@sec.Id)">
                                                    <i class="bi bi-trash"></i> Delete Section
                                                </button>
                                            </div>
                                            
                                            @if (sec.Lessons != null && sec.Lessons.Any())
                                            {
                                                <ul class="list-group">
                                                    @foreach (var lesson in sec.Lessons)
                                                    {
                                                        <li class="list-group-item d-flex justify-content-between align-items-center text-dark">
                                                            <div>
                                                                <strong>@lesson.Title</strong>
                                                                <span class="badge bg-info ms-2">@lesson.DurationInMinutes min</span>
                                                                <br/>
                                                                <small class="text-muted"><i class="bi bi-link-45deg"></i> <a href="@lesson.VideoUrl" target="_blank">@lesson.VideoUrl</a></small>
                                                            </div>
                                                            <div class="d-flex align-items-center gap-2">
                                                                <span class="badge bg-dark">Order: @lesson.DisplayOrder</span>
                                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteLesson(@lesson.Id)" title="Delete Lesson">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            </div>
                                                        </li>
                                                    }
                                                </ul>
                                            }
                                            else
                                            {
                                                <p class="text-muted text-center mb-0">No lessons in this section yet.</p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-info text-dark">No sections found. Start by adding a new section.</div>
                        }
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary"
                                onclick="document.getElementById('edit-details-tab').click()">
                            <i class="bi bi-arrow-left me-1"></i> Previous
                        </button>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-lg me-1"></i> Save Changes
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</form>

<!-- Add Section Modal -->
<div class="modal fade" id="addSectionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-dark">Add New Section</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-dark">
                <div id="addSectionForm">
                    <input type="hidden" id="courseId" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label">Section Title</label>
                        <input type="text" class="form-control" id="sectionTitle" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Display Order</label>
                        <input type="number" class="form-control" id="sectionOrder" value="1" required />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="addSection()">Save Section</button>
            </div>
        </div>
    </div>
</div>

<!-- Add Lesson Modal -->
<div class="modal fade" id="addLessonModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-dark">Add New Lesson</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-dark">
                <div id="addLessonForm">
                    <input type="hidden" id="lessonSectionId" />
                    <div class="mb-3">
                        <label class="form-label">Lesson Title</label>
                        <input type="text" class="form-control" id="lessonTitle" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Video Embed URL (e.g., https://www.youtube.com/embed/...)</label>
                        <input type="url" class="form-control" id="lessonVideoUrl" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Duration (Minutes)</label>
                        <input type="number" class="form-control" id="lessonDuration" value="10" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Display Order</label>
                        <input type="number" class="form-control" id="lessonOrder" value="1" required />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="addLesson()">Save Lesson</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        // Tab preservation across reloads
        $(document).ready(function() {
            var activeTab = '@ViewBag.ActiveTab' || sessionStorage.getItem('activeEditCourseTab');
            if (activeTab) {
                var tabId = activeTab === 'sessions' ? 'edit-sessions-tab' : activeTab;
                var tabEl = document.querySelector('#' + tabId);
                if (tabEl) {
                    var tab = new bootstrap.Tab(tabEl);
                    tab.show();
                    // Clear the sessionStorage so subsequent reloads default to user choice
                    sessionStorage.setItem('activeEditCourseTab', tabId);
                }
            }

            // Save active tab on click
            $('button[data-bs-toggle="pill"]').on('shown.bs.tab', function(e) {
                sessionStorage.setItem('activeEditCourseTab', e.target.id);
            });
        });

        // Live thumbnail preview + file validation
        document.getElementById('thumbnailInput').addEventListener('change', function (e) {
            const file = e.target.files[0];
            const maxSizeMB = 5;
            const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];

            if (!file) return;

            // Validate type
            if (!allowedTypes.includes(file.type)) {
                alert('Invalid file type. Please upload a JPG, PNG, GIF, or WebP image.');
                this.value = '';
                return;
            }

            // Validate size
            if (file.size > maxSizeMB * 1024 * 1024) {
                alert(`File is too large. Maximum allowed size is ${maxSizeMB}MB. Your file is ${(file.size / 1024 / 1024).toFixed(1)}MB.`);
                this.value = '';
                return;
            }

            // Show preview
            const reader = new FileReader();
            reader.onload = function (ev) {
                let img = document.getElementById('previewImg');
                const fallback = document.getElementById('previewFallback');

                if (!img) {
                    img = document.createElement('img');
                    img.id = 'previewImg';
                    img.style.cssText = 'width:100%;height:100%;object-fit:cover;';
                    document.getElementById('previewBox').prepend(img);
                }

                img.src = ev.target.result;
                img.style.display = 'block';
                if (fallback) fallback.style.display = 'none';

                document.getElementById('fileInfo').textContent =
                    `${file.name} (${(file.size / 1024).toFixed(0)} KB)`;
            };
            reader.readAsDataURL(file);
        });

        // Manage Curriculum Functions
        function openAddLessonModal(sectionId) {
            document.getElementById('lessonSectionId').value = sectionId;
            var myModal = new bootstrap.Modal(document.getElementById('addLessonModal'));
            myModal.show();
        }

        function addSection() {
            var data = {
                CourseId: parseInt(document.getElementById('courseId').value),
                Title: document.getElementById('sectionTitle').value,
                DisplayOrder: parseInt(document.getElementById('sectionOrder').value)
            };

            fetch('/Instructor/CreateSection', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            })
            .then(res => {
                if(res.ok) {
                    location.reload();
                } else {
                    alert('Error creating section. Please make sure the API is running and returning success.');
                }
            });
        }

        function addLesson() {
            var data = {
                SectionId: parseInt(document.getElementById('lessonSectionId').value),
                Title: document.getElementById('lessonTitle').value,
                VideoUrl: document.getElementById('lessonVideoUrl').value,
                DurationInMinutes: parseInt(document.getElementById('lessonDuration').value),
                DisplayOrder: parseInt(document.getElementById('lessonOrder').value),
                ContentType: 0 // Enum mapping for Video
            };

            fetch('/Instructor/CreateLesson', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            })
            .then(res => {
                if(res.ok) {
                    location.reload();
                } else {
                    alert('Error creating lesson. Please make sure the API is running and returning success.');
                }
            });
        }

        function deleteSection(sectionId) {
            if (confirm('Are you sure you want to delete this section and all of its lessons?')) {
                fetch('/Instructor/DeleteSection/' + sectionId, {
                    method: 'POST'
                })
                .then(res => {
                    if (res.ok) {
                        location.reload();
                    } else {
                        alert('Error deleting section.');
                    }
                });
            }
        }

        function deleteLesson(lessonId) {
            if (confirm('Are you sure you want to delete this lesson?')) {
                fetch('/Instructor/DeleteLesson/' + lessonId, {
                    method: 'POST'
                })
                .then(res => {
                    if (res.ok) {
                        location.reload();
                    } else {
                        alert('Error deleting lesson.');
                    }
                });
            }
        }

        // Unsaved changes warning
        let formDirty = false;
        document.querySelectorAll('input:not([type=hidden]), textarea, select').forEach(el => {
            el.addEventListener('change', () => formDirty = true);
        });
        window.addEventListener('beforeunload', (e) => {
            if (formDirty) { e.preventDefault(); e.returnValue = ''; }
        });
        // Cancel button and form submit should not trigger the warning
        const cancelBtn = document.getElementById('cancelBtn');
        if (cancelBtn) {
            cancelBtn.addEventListener('click', () => formDirty = false);
        }
        const editCourseForm = document.getElementById('editCourseForm');
        if (editCourseForm) {
            editCourseForm.addEventListener('submit', () => formDirty = false);
        }
    </script>
}
