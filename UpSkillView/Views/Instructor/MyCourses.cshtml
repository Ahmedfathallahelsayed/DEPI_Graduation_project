@model List<Application.Courses.DTOs.Course.CourseSummaryDto>
@{
    ViewData["Title"] = "My Courses";
    Layout = "_DashboardLayout";
    var apiBase = ViewBag.ApiBaseUrl as string ?? "";
}

<!-- Page Header -->
<div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4 gap-3">
    <div>
        <h2 class="mb-1">My Courses</h2>
        <p class="text-muted mb-0">Manage and track all your created courses.</p>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <div class="input-group" style="width:230px;">
            <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
            <input type="text" id="courseSearch" class="form-control"
                   placeholder="Search courses..." oninput="filterCourses()" />
        </div>
        <a asp-controller="Instructor" asp-action="CreateCourse" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="bi bi-plus-lg"></i> New Course
        </a>
    </div>
</div>

<!-- Alerts -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Course Cards -->
<div class="row g-4" id="courseGrid">
    @if (Model != null && Model.Any())
    {
        foreach (var course in Model)
        {
            var thumbnailSrc = !string.IsNullOrEmpty(course.ThumbnailUrl)
                ? apiBase + course.ThumbnailUrl
                : "https://placehold.co/600x340/2563EB/FFFFFF?text=No+Thumbnail";

            <div class="col-md-6 col-xl-4">
                <div class="card h-100 border-0 shadow-sm card-hover">

                    <!-- Thumbnail -->
                    <div style="position:relative; overflow:hidden; height:160px;">
                        <img src="@thumbnailSrc" class="w-100 h-100"
                             alt="@course.Title thumbnail"
                             style="object-fit:cover;"
                             onerror="this.src='https://placehold.co/600x340/2563EB/FFFFFF?text=No+Thumbnail'" />

                        <!-- Status Badge overlay -->
                        <div style="position:absolute; top:10px; right:10px;">
                            @if (course.Status == Domain.Enum.CourseStatus.Published)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-broadcast me-1"></i>Published
                                </span>
                            }
                            else if (course.Status == Domain.Enum.CourseStatus.SubmittedForApproval)
                            {
                                <span class="badge bg-info text-dark">
                                    <i class="bi bi-hourglass-split me-1"></i>Under Review
                                </span>
                            }
                            else if (course.Status == Domain.Enum.CourseStatus.Archived)
                            {
                                <span class="badge bg-secondary">
                                    <i class="bi bi-archive me-1"></i>Archived
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-pencil me-1"></i>Draft
                                </span>
                            }
                        </div>
                    </div>

                    <!-- Card Body -->
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-primary-soft mb-2 align-self-start">@course.CategoryName</span>
                        <h5 class="card-title fw-semibold mb-1" style="line-height:1.3; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                            @course.Title
                        </h5>
                        <p class="text-muted small mb-3" style="display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                            @course.ShortDescription
                        </p>

                        @if (course.Status == Domain.Enum.CourseStatus.Draft && !string.IsNullOrEmpty(course.RejectionReason))
                        {
                            <div class="alert alert-danger p-2 mb-3 small" style="font-size: 0.8rem;">
                                <i class="bi bi-exclamation-octagon me-1"></i>
                                <strong>Rejection Reason:</strong> @course.RejectionReason
                            </div>
                        }

                        <!-- Stats -->
                        <div class="d-flex gap-3 small text-muted mt-auto mb-3">
                            <span><i class="bi bi-people me-1"></i>@course.EnrollmentCount students</span>
                            <span><i class="bi bi-collection me-1"></i>@course.SectionCount sections</span>
                            <span><i class="bi bi-tag me-1"></i>$@course.Price.ToString("0.00")</span>
                        </div>
                    </div>

                    <!-- Card Footer Actions -->
                    <div class="card-footer bg-white border-top pt-2 pb-3 d-flex gap-2 flex-wrap">

                        <!-- Manage Content -->
                        <a asp-action="ManageContent" asp-route-id="@course.Id"
                           class="btn btn-outline-info btn-sm flex-grow-1">
                            <i class="bi bi-collection-play me-1"></i> Curriculum
                        </a>

                        <!-- Edit -->
                        <a asp-action="EditCourse" asp-route-id="@course.Id"
                           class="btn btn-outline-primary btn-sm flex-grow-1"
                           title="@(course.Status == Domain.Enum.CourseStatus.Published ? "Editing will reset course to Draft" : "Edit Course")">
                            <i class="bi bi-pencil-square me-1"></i> Edit
                        </a>

                        <!-- Manage Curriculum -->
                        <a asp-action="ManageContent" asp-route-id="@course.Id"
                           class="btn btn-outline-success btn-sm flex-grow-1">
                            <i class="bi bi-collection me-1"></i> Curriculum
                        </a>

                        <!-- Submit for Review (only Draft) -->
                        @if (course.Status == Domain.Enum.CourseStatus.Draft)
                        {
                            <form asp-action="SubmitForReview" method="post" class="flex-grow-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@course.Id" />
                                <button type="submit" class="btn btn-outline-warning btn-sm w-100"
                                        title="Submit for admin review">
                                    <i class="bi bi-send me-1"></i> Submit
                                </button>
                            </form>
                        }

                        <!-- Unpublish (only Published) -->
                        @if (course.Status == Domain.Enum.CourseStatus.Published)
                        {
                            <form asp-action="UnpublishCourse" method="post" class="flex-grow-1"
                                  onsubmit="return confirm('Unpublish this course? It will be removed from the catalog and moved back to Draft.')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@course.Id" />
                                <button type="submit" class="btn btn-outline-secondary btn-sm w-100"
                                        title="Move course back to Draft">
                                    <i class="bi bi-eye-slash me-1"></i> Unpublish
                                </button>
                            </form>
                        }

                        <!-- Delete (only Draft/Archived with zero enrollments) -->
                        @if ((course.Status == Domain.Enum.CourseStatus.Draft ||
                              course.Status == Domain.Enum.CourseStatus.Archived) &&
                              course.EnrollmentCount == 0)
                        {
                            <form asp-action="DeleteCourse" asp-route-id="@course.Id" method="post"
                                  onsubmit="return confirm('Are you sure you want to delete this course? This cannot be undone.')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete Course">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        }

                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <!-- Empty State -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-5">
                    <i class="bi bi-journal-plus" style="font-size:3.5rem; color:var(--text-muted);"></i>
                    <h4 class="mt-3 mb-2">No courses yet</h4>
                    <p class="text-muted mb-4">Get started by creating your first course.</p>
                    <a asp-controller="Instructor" asp-action="CreateCourse" class="btn btn-primary">
                        <i class="bi bi-plus-lg me-2"></i>Create Your First Course
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function filterCourses() {
            const q = document.getElementById('courseSearch').value.toLowerCase();
            document.querySelectorAll('#courseGrid .col-md-6').forEach(card => {
                card.style.display = card.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        }
    </script>
}
