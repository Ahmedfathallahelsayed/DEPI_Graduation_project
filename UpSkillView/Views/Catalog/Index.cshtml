@model List<Application.CourseContent.DTOs.StudentCourseSummaryDto>
@{
    ViewData["Title"] = "Course Catalog";
}

<div class="container">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">All Courses</li>
        </ol>
    </nav>

    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h1 class="mb-0">All Courses</h1>
            <p class="text-muted mt-2 mb-0">Explore our available courses to expand your skills.</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <form asp-action="Index" method="get" class="d-inline-flex align-items-center gap-2">
                @if (ViewBag.SelectedCategoryId != null)
                {
                    <input type="hidden" name="categoryId" value="@ViewBag.SelectedCategoryId" />
                }
                <input type="text" name="search" class="form-control w-auto" placeholder="Search..." value="@ViewBag.SearchQuery" />
                <button type="submit" class="btn btn-outline-primary">Search</button>
            </form>
        </div>
    </div>

    <div class="row">
        <!-- Sidebar Filters -->
        <div class="col-lg-3 mb-4 mb-lg-0">
            <div class="card p-3 sticky-top" style="top: 100px; z-index: 1;">
                <h5 class="mb-3">Filters</h5>
                
                <div class="mb-3">
                    <h6 class="text-muted small fw-bold text-uppercase mb-2">Categories</h6>
                    <div class="list-group list-group-flush rounded border">
                        <a asp-action="Index" asp-route-search="@ViewBag.SearchQuery" asp-route-categoryId=""
                           class="list-group-item list-group-item-action py-2 @(ViewBag.SelectedCategoryId == null ? "active text-white bg-primary" : "text-dark")" style="font-size: 0.9rem;">
                            All Categories
                        </a>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var cat in (List<Application.Courses.DTOs.Category.CategoryResponseDto>)ViewBag.Categories)
                            {
                                <a asp-action="Index" asp-route-search="@ViewBag.SearchQuery" asp-route-categoryId="@cat.Id"
                                   class="list-group-item list-group-item-action py-2 @(ViewBag.SelectedCategoryId == cat.Id ? "active text-white bg-primary" : "text-dark")" style="font-size: 0.9rem;">
                                    @cat.Name
                                </a>
                            }
                        }
                    </div>
                </div>

                <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">Clear Filters</a>
            </div>
        </div>

        <!-- Course Grid -->
        <div class="col-lg-9">
            <div class="row g-4 mb-5">
                @if (Model != null && Model.Any())
                {
                    foreach (var course in Model)
                    {
                        <div class="col-md-6 col-xl-4">
                            <div class="card course-card h-100 card-hover">
                                <a asp-action="Details" asp-route-id="@course.CourseId">
                                    <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="card-img-top" alt="@course.Title">
                                </a>
                                <div class="card-body d-flex flex-column">
                                    <span class="badge bg-primary-soft mb-2 align-self-start">@course.CategoryName</span>
                                    <h5 class="card-title">
                                        <a asp-action="Details" asp-route-id="@course.CourseId" class="text-dark text-decoration-none">@course.Title</a>
                                    </h5>
                                    <p class="course-instructor mb-2">Instructor: @course.InstructorName</p>
                                    <div class="d-flex align-items-center mb-3">
                                        <span class="text-warning me-1"><i class="bi bi-star-fill"></i></span>
                                        <span class="text-muted small">@(course.IsEnrolled ? "(Enrolled)" : "")</span>
                                    </div>
                                    <div class="mt-auto d-flex justify-content-between align-items-center">
                                        <span class="course-price">$@(course.Price.ToString("0.00"))</span>
                                        <a asp-action="Details" asp-route-id="@course.CourseId" class="btn btn-sm btn-outline-primary">Details</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <i class="bi bi-search fs-1 text-muted mb-3 d-block"></i>
                        <h5>No courses found</h5>
                        <p class="text-muted">Try adjusting your search criteria.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
