@model Application.CourseContent.DTOs.StudentCourseDetailsDto
@{
    ViewData["Title"] = Model.Title;
}

<!-- Course Header -->
<div class="bg-dark text-white py-5 mb-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <!-- Breadcrumb -->
                <nav aria-label="breadcrumb" class="mb-3">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-action="Index" class="text-white-50 text-decoration-none">Courses</a></li>
                        <li class="breadcrumb-item"><a href="#" class="text-white-50 text-decoration-none">@Model.CategoryName</a></li>
                        <li class="breadcrumb-item active text-white" aria-current="page">@Model.Title</li>
                    </ol>
                </nav>

                <h1 class="display-5 fw-bold mb-3">@Model.Title</h1>
                <p class="lead mb-4 opacity-75">@Model.Description</p>

                <div class="d-flex flex-wrap align-items-center gap-4 mb-4">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-person-circle fs-4 me-2"></i>
                        <span>Created by <a href="#" class="text-white text-decoration-none text-decoration-underline-hover">@Model.InstructorName</a></span>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4 mt-4 mt-lg-0">
                <div class="card text-dark shadow-lg">
                    <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="card-img-top" alt="Course Image">
                    <div class="card-body p-4">
                        <h2 class="fw-bold mb-4">$@Model.Price.ToString("0.00")</h2>
                        
                        @if (Model.IsEnrolled)
                        {
                            <a asp-controller="Student" asp-action="CoursePlayer" asp-route-id="@Model.CourseId" class="btn btn-success w-100 py-3 fw-bold mb-3">Go to Course</a>
                        }
                        else
                        {
                            <form asp-controller="Student" asp-action="Enroll" method="post">
                                <input type="hidden" name="courseId" value="@Model.CourseId" />
                                <button type="submit" class="btn btn-primary w-100 py-3 fw-bold mb-3">Enroll Now</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row">
        <div class="col-lg-8">
            <!-- Course Content -->
            <div class="mb-5">
                <h3 class="fw-bold mb-4">Course Content</h3>
                
                <div class="accordion" id="courseCurriculum">
                    @if (Model.Sections != null && Model.Sections.Any())
                    {
                        for (int i = 0; i < Model.Sections.Count; i++)
                        {
                            var section = Model.Sections[i];
                            <div class="accordion-item">
                                <h2 class="accordion-header" id="heading@(i)">
                                    <button class="accordion-button @(i == 0 ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#collapse@(i)" aria-expanded="@(i == 0 ? "true" : "false")" aria-controls="collapse@(i)">
                                        <div class="w-100 d-flex justify-content-between align-items-center pe-3">
                                            <strong>@section.Title</strong>
                                            <span class="text-muted small fw-normal">@(section.Lessons?.Count ?? 0) lectures</span>
                                        </div>
                                    </button>
                                </h2>
                                <div id="collapse@(i)" class="accordion-collapse collapse @(i == 0 ? "show" : "")" aria-labelledby="heading@(i)" data-bs-parent="#courseCurriculum">
                                    <div class="accordion-body p-0">
                                        <ul class="list-group list-group-flush">
                                            @if (section.Lessons != null)
                                            {
                                                foreach (var lesson in section.Lessons)
                                                {
                                                    <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                                                        <div class="d-flex align-items-center">
                                                            <i class="bi bi-play-circle-fill text-muted me-3 fs-5"></i>
                                                            <span class="text-dark">@lesson.Title</span>
                                                        </div>
                                                        @if (lesson.IsFreePreview)
                                                        {
                                                            <a href="#" class="text-primary text-decoration-none small">Preview</a>
                                                        }
                                                    </li>
                                                }
                                            }
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No sections available yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
