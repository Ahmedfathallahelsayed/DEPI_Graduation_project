<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - UpSkill LMS</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link href="~/css/style.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-main">

    <!-- Simple Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
        <div class="container">
            <a class="navbar-brand m-0" asp-controller="Home" asp-action="Index">
                <i class="bi bi-book-half me-2 text-primary"></i>UpSkill LMS
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Catalog" asp-action="Index">Browse Catalog</a>
                    </li>
                </ul>
                <div class="d-flex gap-2">
                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Student"))
                        {
                            <a asp-controller="Student" asp-action="Dashboard" class="btn btn-outline-primary">Dashboard</a>
                        }
                        else if (User.IsInRole("Instructor"))
                        {
                            <a asp-controller="Instructor" asp-action="Dashboard" class="btn btn-outline-primary">Dashboard</a>
                        }
                        else if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-outline-primary">Dashboard</a>
                        }
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Log In</a>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary">Sign Up</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="py-5">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted bg-white py-4 mt-auto">
        <div class="container text-center">
            &copy; 2026 - UpSkill LMS Graduation Project
        </div>
    </footer>

    <!-- Bootstrap JS Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Custom JS -->
    <script src="~/js/script.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
