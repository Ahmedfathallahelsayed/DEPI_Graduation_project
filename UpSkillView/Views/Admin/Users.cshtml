@model List<Application.Admin.DTOs.UserDto>
@{
    ViewData["Title"] = "Manage Users";
    Layout = "_DashboardLayout";
}

<div class="dashboard-main flex-grow-1 p-4 w-100">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">User Management</h2>
            <p class="text-muted mb-0">View and manage all registered accounts on the platform.</p>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Users Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom pt-4 pb-3 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <ul class="nav nav-pills" role="tablist" id="roleTabs">
                <li class="nav-item">
                    <button class="nav-link active bg-light text-dark fw-medium border px-3 py-1 me-2 role-filter-tab" data-role="All" type="button">All Users (@Model.Count)</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link bg-transparent text-muted fw-medium px-3 py-1 me-2 role-filter-tab" data-role="Student" type="button">Students (@Model.Count(u => u.Role == "Student"))</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link bg-transparent text-muted fw-medium px-3 py-1 role-filter-tab" data-role="Instructor" type="button">Instructors (@Model.Count(u => u.Role == "Instructor"))</button>
                </li>
            </ul>
            
            <div class="input-group" style="max-width: 300px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="userSearch" class="form-control border-start-0 ps-0" placeholder="Search by name or email...">
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-custom mb-0 table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">User</th>
                            <th>Role</th>
                            <th>Joined Date</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var user in Model)
                            {
                                <tr data-role="@user.Role">
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center">
                                            <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(user.FullName)&background=random" alt="User" width="40" class="rounded-circle me-3">
                                            <div class="user-info">
                                                <h6 class="mb-0 fw-bold">@user.FullName</h6>
                                                <small class="text-muted">@user.Email</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        @if (user.Role == "Admin")
                                        {
                                            <span class="badge bg-danger-soft text-danger border">Admin</span>
                                        }
                                        else if (user.Role == "Instructor")
                                        {
                                            <span class="badge bg-primary-soft text-primary border">Instructor</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark border">Student</span>
                                        }
                                    </td>
                                    <td class="py-3 text-secondary">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td class="py-3">
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success-soft text-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-soft text-danger">Blocked</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4 py-3">
                                        <button class="btn btn-sm btn-outline-secondary me-1" onclick="openEditModal('@user.Id', '@JavaScriptEncoder.Default.Encode(user.FullName)', '@JavaScriptEncoder.Default.Encode(user.PhoneNumber)')">Edit</button>
                                        
                                        @if (user.IsActive)
                                        {
                                            <form asp-action="Block" asp-route-id="@user.Id" method="post" class="d-inline-block">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Block</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Unblock" asp-route-id="@user.Id" method="post" class="d-inline-block">
                                                <button type="submit" class="btn btn-sm btn-outline-success">Unblock</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No users found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1" aria-labelledby="editUserModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-sm">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="editUserModalLabel">Edit User Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="EditUser" method="post">
                <input type="hidden" name="id" id="editUserId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="editFullName" class="form-label">Full Name</label>
                        <input type="text" class="form-control" name="fullName" id="editFullName" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label for="editPhoneNumber" class="form-label">Phone Number</label>
                        <input type="text" class="form-control" name="phoneNumber" id="editPhoneNumber" maxlength="20" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@using System.Text.Encodings.Web;

@section Scripts {
    <script>
        function openEditModal(id, fullName, phoneNumber) {
            document.getElementById('editUserId').value = id;
            document.getElementById('editFullName').value = fullName;
            document.getElementById('editPhoneNumber').value = phoneNumber;
            
            var editModal = new bootstrap.Modal(document.getElementById('editUserModal'));
            editModal.show();
        }

        $(document).ready(function () {
            // Search filter
            $("#userSearch").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                filterTable(value, getActiveTabRole());
            });

            // Tab filter
            $(".role-filter-tab").on("click", function () {
                $(".role-filter-tab").removeClass("active bg-light text-dark fw-medium border").addClass("bg-transparent text-muted");
                $(this).addClass("active bg-light text-dark fw-medium border").removeClass("bg-transparent text-muted");
                
                var value = $("#userSearch").val().toLowerCase();
                filterTable(value, getActiveTabRole());
            });

            function getActiveTabRole() {
                var activeTab = $(".role-filter-tab.active").data("role");
                return activeTab;
            }

            function filterTable(searchText, roleText) {
                $("#usersTableBody tr").filter(function () {
                    var nameEmail = $(this).find(".user-info").text().toLowerCase();
                    var role = $(this).data("role");
                    
                    var matchesSearch = nameEmail.indexOf(searchText) > -1;
                    var matchesRole = roleText === "All" || role === roleText;
                    
                    $(this).toggle(matchesSearch && matchesRole);
                });
            }
        });
    </script>
}
